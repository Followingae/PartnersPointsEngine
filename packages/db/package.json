{
  "name": "@rfm-loyalty/db",
  "version": "0.1.0",
  "private": true,
  "license": "UNLICENSED",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./rls.sql": "./prisma/sql/rls.sql"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "scripts": {
    "db:generate": "prisma generate",
    "build": "prisma generate && tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "migrate:baseline": "prisma migrate diff --from-empty --to-schema-datamodel prisma/schema.prisma --script",
    "db:migrate": "prisma migrate deploy",
    "db:apply": "tsx scripts/apply-sql.ts",
    "dev:db": "tsx scripts/dev-db.ts",
    "seed": "tsx prisma/seed.ts",
    "test": "vitest run",
    "lint": "eslint .",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@node-rs/argon2": "^2.0.2",
    "@prisma/client": "^6.3.0"
  },
  "devDependencies": {
    "@rfm-loyalty/config": "workspace:*",
    "@rfm-loyalty/shared": "workspace:*",
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.10",
    "embedded-postgres": "17.10.0-beta.17",
    "eslint": "^9.18.0",
    "pg": "^8.13.1",
    "prisma": "^6.3.0",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3",
    "vitest": "^3.0.0"
  }
}
