# ─────────────────────────────────────────────────────────────────────────────
# RFM Loyalty Engine — environment template. Copy to .env and fill in.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database (Supabase Postgres) ─────────────────────────────────────────────
# Pooled (Supavisor, TRANSACTION mode) — runtime queries (RLS-safe: SET LOCAL).
DATABASE_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Direct (session, port 5432) — Prisma Migrate / introspection ONLY.
DIRECT_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"
# Dedicated NON-OWNER, NOINHERIT, NO-BYPASSRLS login role the request path uses.
APP_DATABASE_URL="postgresql://loyalty_app:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"

# ── Redis (DigitalOcean Managed Redis / Valkey) — BullMQ + cache + rate-limit ──
REDIS_URL="rediss://default:<password>@<host>:25061"

# ── Auth (in-house; no third-party IdP) ──────────────────────────────────────
JWT_ACCESS_SECRET="dev-access-secret-change-me"
JWT_REFRESH_SECRET="dev-refresh-secret-change-me"
JWT_ACCESS_TTL_SECONDS="900"
JWT_REFRESH_TTL_SECONDS="2592000"
TOTP_ISSUER="RFM Loyalty"
TERMINAL_HMAC_SKEW_SECONDS="300"

# ── PII envelope encryption (dev only; use a managed KMS in prod) ─────────────
PII_MASTER_KEY_BASE64="REPLACE_WITH_BASE64_32_BYTE_KEY"

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV="development"
API_PORT="3001"
API_BASE_URL="http://localhost:3001"
LOG_LEVEL="debug"
DEFAULT_REGION="uae"
DEFAULT_CURRENCY="AED"

# ── Frontend consoles (set these in the Vercel project dashboards) ────────────
# Brand console (platform.partnerspoints.ae) AND superadmin console both need:
NEXT_PUBLIC_API_URL="https://api.partnerspoints.ae/v1"
# Superadmin console only — where "Manage as brand" opens the brand console:
NEXT_PUBLIC_BRAND_URL="https://platform.partnerspoints.ae"
