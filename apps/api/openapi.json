  "info": {
    "title": "RFM Loyalty Engine API",
    "description": "Multi-tenant, closed-loop, B2B2C loyalty engine. Four surfaces: Superadmin (/v1/admin), Brand Admin (/v1/manage), Customer (/v1/customer), Terminal (/v1/terminal).",
    "version": "v1",
    "contact": {}
  },
  "tags": [
    {
      "name": "system",
      "description": ""
    },
    {
      "name": "auth",
      "description": ""
    }
  ],
  "servers": [],
  "components": {
    "securitySchemes": {
      "admin": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      },
      "customer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      },
      "terminal-hmac": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization"
      }
    },
    "schemas": {
      "LoginDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "superadmin@rfm-loyalty.dev"
          },
          "password": {
            "type": "string",
            "example": "ChangeMe123!"
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "MfaVerifyDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string"
          },
          "password": {
            "type": "string"
          },
          "code": {
            "type": "string",
            "example": "123456"
          }
        },
        "required": [
          "email",
          "password",
          "code"
        ]
      },
      "RefreshDto": {
        "type": "object",
        "properties": {
          "refreshToken": {
            "type": "string"
          }
        },
        "required": [
          "refreshToken"
        ]
      },
      "ConfirmMfaDto": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
            "example": "123456"
          }
        },
        "required": [
          "code"
        ]
      },
      "OtpRequestDto": {
        "type": "object",
        "properties": {
          "phone": {
            "type": "string",
            "example": "+971500000001"
          },
          "brandId": {
            "type": "string",
            "description": "The brand the customer is signing into (closed-loop)."
          }
        },
        "required": [
          "phone",
          "brandId"
        ]
      },
      "OtpVerifyDto": {
        "type": "object",
        "properties": {
          "phone": {
            "type": "string",
            "example": "+971500000001"
          },
          "code": {
            "type": "string",
            "example": "123456"
          },
          "brandId": {
            "type": "string"
          }
        },
        "required": [
          "phone",
          "code",
          "brandId"
        ]
      },
      "RedeemDto": {
        "type": "object",
        "properties": {
          "idempotencyKey": {
            "type": "string",
            "description": "Client-generated idempotency key"
          }
        },
        "required": [
          "idempotencyKey"
        ]
      },
      "RedeemReferralDto": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          }
        },
        "required": [
          "code"
        ]
      },
      "CreateEarnRuleDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "priority": {
            "type": "number",
            "default": 0
          },
          "enabled": {
            "type": "boolean",
            "default": true
          },
          "definition": {
            "type": "object",
            "description": "{ condition?, actions[] } per the rules engine"
          }
        },
        "required": [
          "name",
          "definition"
        ]
      },
      "CreateCatalogItemDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "pointsCost": {
            "type": "number",
            "description": "Points cost (whole integer)",
            "example": 500
          },
          "kind": {
            "type": "string",
            "default": "voucher"
          }
        },
        "required": [
          "name",
          "pointsCost"
        ]
      },
      "CreateTierDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "threshold": {
            "type": "number",
            "description": "Lifetime points to reach this tier"
          },
          "multiplierBps": {
            "type": "number",
            "default": 10000,
            "description": "Earn multiplier in bps (10000 = 1.0x)"
          }
        },
        "required": [
          "name",
          "threshold"
        ]
      },
      "CreateCampaignDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "startsAt": {
            "type": "string"
          },
          "endsAt": {
            "type": "string"
          },
          "definition": {
            "type": "object",
            "description": "{ condition?, actions[] }"
          }
        },
        "required": [
          "name",
          "definition"
        ]
      },
      "CreateBadgeDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "icon": {
            "type": "string"
          },
          "rewardPoints": {
            "type": "number",
            "default": 0
          }
        },
        "required": [
          "name"
        ]
      },
      "CreateChallengeDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "target": {
            "type": "number",
            "description": "Lifetime points target"
          },
          "rewardPoints": {
            "type": "number",
            "default": 0
          },
          "badgeId": {
            "type": "string"
          }
        },
        "required": [
          "name",
          "target"
        ]
      },
      "AdminEarnDto": {
        "type": "object",
        "properties": {
          "membershipId": {
            "type": "string"
          },
          "amountMinor": {
            "type": "number",
            "description": "Spend in minor units"
          },
          "channel": {
            "type": "string",
            "enum": [
              "online",
              "in_store"
            ]
          },
          "isVisit": {
            "type": "boolean"
          },
          "items": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "sourceEvent": {
            "type": "string"
          },
          "idempotencyKey": {
            "type": "string"
          }
        },
        "required": [
          "membershipId",
          "idempotencyKey"
        ]
      },
      "ResolveDto": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "phone",
              "email",
              "qr",
              "nfc",
              "loyalty_id",
              "card_token"
            ]
          },
          "value": {
            "type": "string"
          }
        },
        "required": [
          "type",
          "value"
        ]
      },
      "CartItemDto": {
        "type": "object",
        "properties": {
          "sku": {
            "type": "string"
          },
          "qty": {
            "type": "number"
          }
        },
        "required": [
          "sku",
          "qty"
        ]
      },
      "QuoteDto": {
        "type": "object",
        "properties": {
          "memberToken": {
            "type": "string"
          },
          "amountMinor": {
            "type": "number"
          },
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CartItemDto"
            }
          },
          "isVisit": {
            "type": "boolean"
          },
          "redeemPoints": {
            "type": "number"
          }
        },
        "required": [
          "memberToken"
        ]
      },
      "TransactionDto": {
        "type": "object",
        "properties": {
          "intent": {
            "type": "string",
            "enum": [
              "earn",
              "redeem"
            ]
          },
          "memberToken": {
            "type": "string"
          },
          "idempotencyKey": {
            "type": "string",
            "description": "Client/POS-generated idempotency key"
          },
          "amountMinor": {
            "type": "number"
          },
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CartItemDto"
            }
          },
          "isVisit": {
            "type": "boolean"
          },
          "points": {
            "type": "number",
            "description": "Points to redeem (intent=redeem)"
          },
          "sourceEvent": {
            "type": "string"
          }
        },
        "required": [
          "intent",
          "memberToken",
          "idempotencyKey"
        ]
      },
      "BatchDto": {
        "type": "object",
        "properties": {
          "operations": {
            "description": "Queued offline operations to replay",
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TransactionDto"
            }
          }
        },
        "required": [
          "operations"
        ]
      },
      "CreateGroupDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "Roastery Holdings"
          },
          "defaultCurrency": {
            "type": "string",
            "example": "AED"
          },
          "homeRegion": {
            "type": "string",
            "example": "uae"
          }
        },
        "required": [
          "name"
        ]
      },
      "CreateBrandDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "slug": {
            "type": "string",
            "example": "camel-bean"
          },
          "currency": {
            "type": "string"
          }
        },
        "required": [
          "name",
          "slug"
        ]
      },
      "CreateBranchDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "code": {
            "type": "string"
          }
        },
        "required": [
          "name"
        ]
      },
      "TopUpDto": {
        "type": "object",
        "properties": {
          "amountMinor": {
            "type": "number",
            "description": "Credit amount in minor units (e.g. fils)"
          },
          "currency": {
            "type": "string",
            "example": "AED"
          },
          "idempotencyKey": {
            "type": "string",
            "description": "Client-generated idempotency key"
          }
        },
        "required": [
          "amountMinor",
          "idempotencyKey"
        ]
      },
      "CostRuleDto": {
        "type": "object",
        "properties": {
          "costPerPointMinor": {
            "type": "number",
            "description": "Drawdown cost per redeemed point (minor units)"
          },
          "platformMarginBps": {
            "type": "number",
            "description": "Platform margin in basis points (1000 = 10%)"
          },
          "issuanceFeeMinor": {
            "type": "number",
            "description": "Issuance fee per point (minor units)"
          },
          "breakageOwner": {
            "type": "string",
            "enum": [
              "merchant",
              "platform",
              "split"
            ]
          }
        },
        "required": [
          "costPerPointMinor"
        ]
      }
    }
  }
}
